DATABASE_URL=postgresql://creativebuilds_app:YOUR_PASSWORD@localhost:5432/creativebuilds
JWT_SECRET=change-this-to-a-long-random-string
PORT=3020
NODE_ENV=production
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
GITHUB_TOKEN=ghp_optional-for-higher-rate-limits
ODYSSEUS_ROOT=/home/pi/Desktop/Odysseus

# Form submission alerts → hello@ (forwards to Gmail via Cloudflare Email Routing)
# Sign up at https://resend.com — free tier works with onboarding@resend.dev as sender
RESEND_API_KEY=re_your_resend_api_key
NOTIFY_EMAIL=hello@creativebuilds.dev
# NOTIFY_FROM=CreativeBuilds <hello@creativebuilds.dev>  # after verifying domain in Resend

